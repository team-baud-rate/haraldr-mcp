{
  "name": "haraldr",
  "version": "0.2.0",
  "description": "MCP server for Haraldr — login and (eventually) domain management tools for AI agents.",
  "type": "module",
  "bin": {
    "haraldr": "src/cli.js"
  },
  "main": "src/server.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/team-baud-rate/haraldr-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/team-baud-rate/haraldr-mcp/issues"
  },
  "homepage": "https://github.com/team-baud-rate/haraldr-mcp#readme",
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "test": "node --test",
    "prelint": "npm run typecheck",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc -p jsconfig.json",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src",
    "skills",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "mcp",
    "haraldr",
    "domains",
    "ai-agent"
  ],
  "license": "MIT"
}
